# ===== แดชบอร์ด =====
PORT=3000
SESSION_SECRET=เปลี่ยนเป็นข้อความยาวๆสุ่มๆของตัวเอง-ห้ามใช้ค่านี้จริง
# หน้า /logs.html (ดู console log แบบ live) มี login แยกต่างหาก ไม่ผูกกับระบบ user หลัก — ใช้ HTTP
# Basic Auth (เบราว์เซอร์เด้ง popup ถามเอง) ค่า default ตรงนี้คือ check / P@ssw0rd ตามที่ขอไว้
# ⚠️ ควรเปลี่ยนเป็นของตัวเองก่อน deploy จริง อย่าปล่อยเป็นค่า default
LOGS_VIEWER_USER=check
LOGS_VIEWER_PASS=P@ssw0rd
# ลืมรหัสผ่าน admin / login ไม่ได้เลย? ตั้งบรรทัดล่างนี้เป็น true แล้วรันเซิร์ฟเวอร์ใหม่ จะรีเซ็ต
# รหัสผ่าน admin เป็นค่าสุ่มใหม่ให้ทันที (โชว์ใน console) — ลบบรรทัดนี้ทิ้งหลัง login ผ่านแล้ว!
# FORCE_RESET_ADMIN_PASSWORD=true

# ===== ที่เก็บข้อมูลถาวร (Upstash Redis — ฟรีถาวร ไม่ต้องบัตรเครดิต) =====
# สมัครที่ https://upstash.com แล้วคัดลอก REST URL / REST TOKEN มาใส่ตรงนี้
# ใช้ token ตัวที่ "อ่าน+เขียนได้" ไม่ใช่ตัว READONLY
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ===== Facebook Marketplace — Apify actor ID (ใช้ก็ต่อเมื่อเปิด provider "apify" ไว้จากหน้า
# "สถานะการเชื่อมต่อ" ในเว็บ — เปิด/ปิด Bright Data/Apify/Watcher ทีละตัวได้จากปุ่มในหน้านั้นเลย
# ไม่ต้องมาแก้ env แล้ว มีผลทันทีไม่ต้องรีสตาร์ทเซิร์ฟเวอร์ (ดูหัวข้อ Bright Data ด้านล่างด้วย) =====
APIFY_MARKETPLACE_ACTOR_ID=get-leads/all-in-one-facebook-scraper

FB_SEARCH_URL=https://www.facebook.com/marketplace/107292532620574/search?query=รถมือสอง
# FB_COOKIES_PATH=./fb-cookies.json   # ← เปิดใช้บรรทัดนี้ถ้า guest mode ใช้ไม่ได้ ต้อง login จริง
FB_HEADLESS=true
FB_SCAN_INTERVAL_MS=15000
FB_RELOAD_INTERVAL_MS=600000

# ===== Facebook Group — ใช้ fb-cookies.json ตัวเดียวกับ Marketplace ตอนเปิด provider "watcher"
# หมุนสแกนทีละกลุ่มตามที่ตั้งไว้ในหน้า settings.html =====
FB_GROUP_SCAN_DELAY_MS=8000
FB_GROUP_CYCLE_PAUSE_MS=60000

# ===== Facebook Group + Marketplace ผ่าน Apify (ทางเลือกสำรอง — ใช้เครดิต ปิดไว้เป็น default
# แล้วเพราะเครดิตฟรีหมดเร็วเกินไปจากการทดสอบจริง) =====
APIFY_TOKEN=
APIFY_GROUP_ACTOR_ID=
APIFY_GROUP_DISCOVERY_ACTOR_ID=
# ⚠️⚠️ ต้องเป็น actor คนละตัวกับ APIFY_GROUP_ACTOR_ID/APIFY_MARKETPLACE_ACTOR_ID เสมอ! ยืนยันแล้ว
# จากการทดสอบจริงว่าถ้าตั้งเป็นตัวเดียวกัน จะได้ 0 รายการทุกครั้ง (หรือ "Actor run did not succeed")
# เพราะ actor scrape โพสต์ไม่รู้จักโครงสร้างหน้าค้นหากลุ่มของ Facebook เลย ต้องหา actor แยกต่างหาก
# ชื่อทำนอง "Facebook Groups Search Scraper" ใน Apify Store — ถ้ายังไม่มี ใช้ปุ่ม "ใช้กลุ่มแนะนำ"
# ในหน้า settings.html แทนไปก่อนได้เลย (คัดกลุ่มไว้ให้แล้วล่วงหน้า ไม่ต้องพึ่ง actor ตัวนี้)
#
# APIFY_RUN_TIMEOUT_MS: เวลาสูงสุดที่รอ Apify actor รันเสร็จ (ทั้ง Marketplace/Group/Discovery)
# ค่า default 8 นาที — ยืนยันแล้วว่า 3 นาที (ค่าเดิม) ไม่พอจริงเวลาค้น 12 รุ่นรถพร้อมกันในคำขอเดียว
# ⚠️ ถ้า deploy บน Render/hosting อื่นที่มี reverse proxy ของตัวเอง (เช่น Render มี timeout ของ
# proxy เองแยกจากเซิร์ฟเวอร์เรา) อาจต้องเช็คเอกสารของ hosting นั้นด้วยว่ารองรับ request ค้างนานขนาด
# นี้ไหม ถ้า proxy ตัดก่อน จะเห็น error ที่หน้าเว็บแม้เราจะตั้ง timeout ของเราเองสูงแค่ไหนก็ตาม
APIFY_RUN_TIMEOUT_MS=480000
FB_GROUP_MAX_ITEMS=40
FB_DISCOVERY_MAX_ITEMS=40
# คำค้นหา/พื้นที่/กลุ่ม Facebook ตั้งผ่านหน้า /settings.html แทน ไม่ต้องตั้งที่นี่
#
# ⚠️ ถ้าจะเปิด provider "apify" อีกครั้งจากหน้า "สถานะการเชื่อมต่อ" ระวังเรื่องเครดิตให้ดี —
# ทดสอบดูอัตราการใช้เครดิตจริงที่ Apify > Billing > Usage ก่อนเปิดใช้จริง
#
# ✅ ทั้ง Marketplace และ Group มี checkpoint/priority self-throttle ของตัวเองแล้ว (ดู DEPLOY.md
# หัวข้อ "ลด Apify CU") — ค่า APIFY_POLL_INTERVAL_MS ด้านล่างเป็นแค่ความถี่ "เช็คว่ามีอะไรครบกำหนด
# สแกนใหม่บ้าง" (เบามาก ไม่เสีย CU ตอนเช็คเฉยๆ) ตั้งถี่ได้อย่างปลอดภัย (เช่น 60000 = เช็คทุก 1 นาที)
# ความถี่สแกนจริงต่อกลุ่ม/พื้นที่คุมด้วย priority (high/normal/low ตั้งได้ในหน้า settings.html)
# ร่วมกับ 6 ค่าด้านล่างนี้แทน
APIFY_POLL_INTERVAL_MS=60000
APIFY_GROUP_HIGH_INTERVAL_MS=180000          # กลุ่ม priority "สูง" ครบกำหนดสแกนใหม่ทุก 3 นาที
APIFY_GROUP_NORMAL_INTERVAL_MS=600000        # กลุ่ม priority "ปกติ" ทุก 10 นาที
APIFY_GROUP_LOW_INTERVAL_MS=1800000          # กลุ่ม priority "ต่ำ" ทุก 30 นาที
APIFY_MARKETPLACE_HIGH_INTERVAL_MS=180000    # พื้นที่ priority "สูง" ครบกำหนดสแกนใหม่ทุก 3 นาที
APIFY_MARKETPLACE_NORMAL_INTERVAL_MS=600000  # พื้นที่ priority "ปกติ" ทุก 10 นาที
APIFY_MARKETPLACE_LOW_INTERVAL_MS=1800000    # พื้นที่ priority "ต่ำ" ทุก 30 นาที
# ตั้งค่าเผื่อจะใช้ webhook แบบ event-driven แทนการ poll (ทางเลือก — ดู DEPLOY.md หัวข้อ "ลด Apify CU")
APIFY_WEBHOOK_SECRET=

# ===== Facebook ผ่าน Bright Data (ทางเลือกใหม่ — จ่ายเฉพาะที่ดึงสำเร็จ ไม่เสียเงินกับ request
# ที่ fail/โดนบล็อก ต่างจาก Apify ที่เสียเครดิตแม้ดึงไม่สำเร็จ) =====
# วิธีสมัคร: https://brightdata.com/cp/start (มีเครดิตฟรีให้ทดลอง)
# วิธีตั้งค่า: Settings > API Keys > สร้าง token ใหม่ มาใส่ด้านล่าง
BRIGHTDATA_API_TOKEN=
BRIGHTDATA_POLL_INTERVAL_MS=300000
# ✅ เปิด/ปิดแต่ละ provider (Bright Data / Apify / Watcher) แยกต่อ Marketplace และ Group ได้จากปุ่ม
# ในหน้า "สถานะการเชื่อมต่อ" ของเว็บโดยตรง มีผลทันที ไม่ต้องมาแก้ env ตรงนี้หรือรีสตาร์ทเซิร์ฟเวอร์เลย
# — ตั้งค่า credential ของตัวไหนไว้ในไฟล์นี้ (BRIGHTDATA_API_TOKEN / APIFY_TOKEN) แค่ทำให้ปุ่มนั้น
# "เปิดได้" เท่านั้น การเปิด/ปิดจริงคุมจากปุ่มในเว็บ (บันทึกถาวรใน Redis ไม่หายตอน deploy ใหม่)

# ===== One2Car / Kaidee (ไม่ต้อง login) =====
ONE2CAR_URL=https://www.one2car.com/en/cars-for-sale?sort=modification_date_search.desc
ONE2CAR_INTERVAL_MS=20000
# ONE2CAR_HEADLESS=false        # ⚠️ ไม่มีผลแล้ว — ใช้ Chrome ร่วมกับ Facebook watcher แล้ว คุม headless ที่ FB_HEADLESS แทน
# ONE2CAR_MAX_ATTEMPTS=2        # ← จำนวนครั้งที่ลองใหม่ (เปิด browser ใหม่ทั้งตัว) ถ้าโดนบล็อก/ได้ 0 รายการ
# ONE2CAR_IMAGE_BACKFILL=false  # ← ปิดการเข้าไปดึงรูปจากหน้ารายละเอียดเพิ่ม (เปิดไว้เป็น default)
# ONE2CAR_IMAGE_BACKFILL_MAX=15 # ← จำนวนคันสูงสุดต่อรอบที่จะเข้าไปดึงรูปเพิ่ม (กันใช้เวลานานเกินไป)
KAIDEE_URL=https://rod.kaidee.com/used-cars/newarrival
KAIDEE_INTERVAL_MS=20000
# PUPPETEER_HEADLESS=false      # ← เหมือนกันแต่คุม headless browser ตอน Kaidee fallback มาใช้ (puppeteerFetch.js)

# ===== Google Sheet (ไม่บังคับ — เว้นว่างไว้ = ปิดฟีเจอร์นี้) =====
# สำหรับ deploy: แปลงไฟล์ service account เป็น base64 ใส่ตัวล่าง (ดูวิธีในคอมเมนต์บนไฟล์ googleSheets.js)
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
GOOGLE_SHEET_ID=
GOOGLE_SHEET_TAB=Listings

# ===== LINE Messaging API (ไม่บังคับ — เว้นว่างไว้ = ปิดฟีเจอร์นี้) =====
LINE_CHANNEL_ACCESS_TOKEN=
LINE_TARGET_ID=

# ===== ส่งต่อไปยัง backend เดิม (ไม่บังคับ — เว้นว่างไว้ = ข้าม ไม่ส่ง) =====
RENDER_URL=
SYNC_SECRET=sync-secret-key

# 🔴 kill switch ฉุกเฉิน — ปิด watcher ได้ตรงนี้โดยไม่ต้องเข้าเว็บเลย (ใช้ตอนเว็บ 502/เข้าไม่ได้)
# ตั้งชื่อแหล่งที่จะบังคับปิด watcher คั่นด้วย comma เช่น "group" หรือ "marketplace,group"
# DISABLE_WATCHER_SOURCES=group

# 🔴 kill switch เพิ่มเติม — ปิด One2Car/Kaidee ได้ทันทีจาก env (ใช้วินิจฉัยปัญหา RAM/OOM)
# DISABLE_POLL_SOURCES=one2car
